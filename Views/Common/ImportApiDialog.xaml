<Window x:Class="MMG.Views.Common.ImportApiDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="API Import"
        Width="420"
        Height="330"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Import 형식 선택"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,14"/>

        <StackPanel Grid.Row="1"
                    Margin="0,0,0,16">
            <TextBlock Text="형식"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>
            <ComboBox x:Name="FormatComboBox"
                      Height="34"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      SelectedIndex="0">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="HorizontalContentAlignment"
                                Value="Center"/>
                    </Style>
                </ComboBox.ItemContainerStyle>
                <ComboBoxItem Content="JSON" Tag="Json"/>
                <ComboBoxItem Content="IDL (준비 중)" Tag="Idl"/>
            </ComboBox>
        </StackPanel>

        <Border Grid.Row="2"
                Background="#F7F8FA"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <TextBlock TextWrapping="Wrap"
                       Foreground="#374151"
                       LineHeight="20"
                       Text="여러 JSON 파일을 한 번에 선택할 수 있고, 각 파일의 data 배열 안에 여러 API가 있으면 모두 가져옵니다. 선택된 폴더가 있으면 그 폴더 아래로 저장됩니다."/>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,20,0,0">
            <Button Content="취소"
                    Click="CancelButton_Click"
                    Width="76"
                    Height="32"
                    Margin="0,0,10,0"
                    Style="{StaticResource CancelButtonStyle}"/>

            <Button Content="다음"
                    Click="ConfirmButton_Click"
                    Width="76"
                    Height="32"
                    Style="{StaticResource ConfirmationButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>