<UserControl x:Class="MMG.Views.API.SavedRequestsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:MMG"
             xmlns:models="clr-namespace:MMG.Models"
             xmlns:converters="clr-namespace:MMG.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="300">
    <UserControl.Resources>
        <!-- Drop Shadow Effect -->
        <DropShadowEffect x:Key="DropShadow"
                          BlurRadius="12"
                          ShadowDepth="4"
                          Direction="315"
                          Color="#80000000"
                          Opacity="0.3"/>

        <!-- 폴더용 컨텍스트 메뉴 -->
        <ContextMenu x:Key="FolderContextMenu">
            <MenuItem Header="새 폴더"
                      Command="{Binding NewFolderCommand}">
                <MenuItem.Icon>
                    <TextBlock Text="📁"
                               FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="새 요청"
                      Command="{Binding NewRequestCommand}">
                <MenuItem.Icon>
                    <TextBlock Text="📃"
                               FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Import"
                      Command="{Binding ImportApisCommand}">
                <MenuItem.Icon>
                    <TextBlock Text="📥"
                               FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="이름 변경"
                      Command="{Binding RenameItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="✏️"
                               FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="삭제"
                      Command="{Binding DeleteItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="🗑️"
                               FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <!-- 요청 파일용 컨텍스트 메뉴 -->
        <ContextMenu x:Key="RequestContextMenu">
            <MenuItem Header="이름 변경"
                      Command="{Binding RenameItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="✏️"
                               FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="복사"
                      Command="{Binding CopyItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="📋"
                               FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="삭제"
                      Command="{Binding DeleteItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="🗑️"
                               FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

            <Style x:Key="AddPopupMenuButtonStyle"
                   TargetType="Button">
                <Setter Property="Background"
                    Value="Transparent"/>
                <Setter Property="BorderThickness"
                    Value="0"/>
                <Setter Property="Foreground"
                    Value="Black"/>
                <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
                <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
                <Setter Property="Padding"
                    Value="10,8"/>
                <Setter Property="MinWidth"
                    Value="150"/>
                <Setter Property="FontSize"
                    Value="12"/>
                <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="4"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                             Value="True">
                        <Setter TargetName="Border"
                            Property="Background"
                            Value="#F0F0F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
                </Setter>
            </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PanelBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource SoftAccent}"
                    BorderBrush="{StaticResource MutedBorder}"
                    BorderThickness="0"
                    CornerRadius="10"
                    Padding="14,14,14,10"
                    Margin="2,2,2,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="API"
                               FontSize="{DynamicResource text-sm}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryColor}"/>

                    <!-- + 버튼 with Dropdown -->
                    <Grid Grid.Column="1"
                          x:Name="AddButtonContainer">
                        <Button x:Name="AddButton"
                                Style="{StaticResource ModernButton}"
                                Width="30"
                                Height="30"
                                ToolTip="새로 추가"
                                MouseEnter="AddButton_MouseEnter"
                            MouseLeave="AddButton_MouseLeave">
                            <Grid Width="12"
                              Height="12"
                              IsHitTestVisible="False">
                            <Border Width="12"
                                Height="3"
                                Background="White"
                                CornerRadius="1.5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                            <Border Width="3"
                                Height="12"
                                Background="White"
                                CornerRadius="1.5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Popup x:Name="AddPopup"
                               PlacementTarget="{Binding ElementName=AddButton}"
                               Placement="Bottom"
                               StaysOpen="True"
                               AllowsTransparency="True"
                               MouseEnter="AddPopup_MouseEnter"
                               MouseLeave="AddPopup_MouseLeave">
                            <Border Background="White"
                                    BorderBrush="#DDDDDD"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Effect="{StaticResource DropShadow}"
                                    MouseEnter="AddPopup_MouseEnter"
                                    MouseLeave="AddPopup_MouseLeave">
                                <StackPanel Margin="2">
                                    <Button Content="📁 New Folder"
                                            Command="{Binding NewFolderCommand}"
                                            Style="{StaticResource AddPopupMenuButtonStyle}"
                                            Click="PopupButton_Click">
                                    </Button>

                                    <Separator Margin="5,2"/>

                                    <Button Content="📥 Import"
                                            Command="{Binding ImportApisCommand}"
                                            Style="{StaticResource AddPopupMenuButtonStyle}"
                                            Click="PopupButton_Click">
                                    </Button>

                                        <Separator Margin="5,2"/>

                                    <Button Content="📃 New Request"
                                            Command="{Binding NewRequestCommand}"
                                            Style="{StaticResource AddPopupMenuButtonStyle}"
                                            Click="PopupButton_Click">
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </Border>

            <!-- Tree View -->
            <TreeView Grid.Row="1"
                      x:Name="RequestTreeView"
                      ItemsSource="{Binding TreeItems}"
                      Margin="6,0,6,6"
                      BorderThickness="0"
                      Background="Transparent"
                      Focusable="True"
                      AllowDrop="True"
                      SelectedItemChanged="TreeView_SelectedItemChanged"
                      KeyDown="TreeView_KeyDown"
                      Drop="TreeView_Drop">
                <!-- 빈 영역을 위한 기본 컨텍스트 메뉴 -->
                <TreeView.ContextMenu>
                    <ContextMenu x:Name="EmptyAreaContextMenu">
                        <MenuItem Header="새 폴더"
                                  Command="{Binding NewFolderCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="📁"
                                           FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="새 요청"
                                  Command="{Binding NewRequestCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="📃"
                                           FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Import"
                                  Command="{Binding ImportApisCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="📥"
                                           FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </TreeView.ContextMenu>

                <TreeView.Resources>
                    <!-- TreeView Item Template -->
                    <HierarchicalDataTemplate DataType="{x:Type models:TreeViewItemModel}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal"
                                    Background="Transparent">
                            <!-- 폴더 아이콘 -->
                            <TextBlock Text="📁"
                                       FontSize="14"
                                       Margin="0,0,5,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ItemType}"
                                                         Value="Folder">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- 요청 아이콘 (📃으로 변경) -->
                            <TextBlock Text="📃"
                                       FontSize="12"
                                       Margin="0,0,5,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ItemType}"
                                                         Value="Request">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- 이름 표시/편집 -->
                            <Grid>
                                <!-- 일반 텍스트 표시 -->
                                <TextBlock Text="{Binding Name}"
                                           FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground"
                                                    Value="#555555"/>
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ItemType}"
                                                             Value="Folder">
                                                    <Setter Property="FontWeight"
                                                            Value="Bold"/>
                                                    <Setter Property="Foreground"
                                                            Value="#333333"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditing}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- 편집용 텍스트박스 -->
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="12"
                                             Width="120"
                                             Height="20"
                                             VerticalAlignment="Center"
                                             x:Name="EditTextBox"
                                             KeyDown="EditTextBox_KeyDown"/>

                                    <Button Content="✓"
                                            Command="{Binding DataContext.SaveRenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Width="20"
                                            Height="20"
                                            FontSize="10"
                                            Margin="2,0,0,0"
                                            Background="#4CAF50"
                                            Foreground="White"
                                            BorderThickness="0"
                                            ToolTip="저장"/>

                                    <Button Content="✗"
                                            Command="{Binding DataContext.CancelRenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Width="20"
                                            Height="20"
                                            FontSize="10"
                                            Margin="2,0,0,0"
                                            Background="#F44336"
                                            Foreground="White"
                                            BorderThickness="0"
                                            ToolTip="취소"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded"
                                Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <Setter Property="IsSelected"
                                Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Setter Property="FontSize"
                                Value="13"/>
                        <Setter Property="Padding"
                                Value="6"/>
                        <Setter Property="Margin"
                                Value="0,2"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="BorderBrush"
                                Value="Transparent"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="AllowDrop"
                                Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ToggleButton x:Name="Expander"
                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                      Visibility="Visible"
                                                      Width="16"
                                                      Height="16"
                                                      Margin="0,0,6,0"
                                                      Grid.Row="0"
                                                      Grid.Column="0"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Focusable="False"
                                                      Cursor="Hand">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Grid Width="16"
                                                          Height="16"
                                                          Background="Transparent"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center">
                                                        <Path x:Name="ExpanderArrow"
                                                              Data="M 4 6 L 8 10 L 12 6"
                                                              StrokeThickness="1.6"
                                                              Stroke="#6B7280"
                                                              StrokeLineJoin="Round"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked"
                                                                 Value="True">
                                                            <Setter TargetName="ExpanderArrow"
                                                                    Property="Data"
                                                                    Value="M 4 10 L 8 6 L 12 10"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>

                                        <Border x:Name="Header"
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ContentPresenter x:Name="PART_Header"
                                                              Margin="6,4"
                                                              ContentSource="Header"/>
                                        </Border>

                                        <ItemsPresenter x:Name="ItemsHost"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="18,4,0,0"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded"
                                                 Value="False">
                                            <Setter TargetName="ItemsHost"
                                                    Property="Visibility"
                                                    Value="Collapsed"/>
                                        </Trigger>
                                        <Trigger Property="HasItems"
                                                 Value="False">
                                            <Setter TargetName="Expander"
                                                    Property="Visibility"
                                                    Value="Collapsed"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected"
                                                 Value="True">
                                            <Setter TargetName="Header"
                                                    Property="Background"
                                                    Value="{StaticResource SoftAccent}"/>
                                            <Setter TargetName="Header"
                                                    Property="BorderBrush"
                                                    Value="{StaticResource PrimaryColor}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled"
                                                 Value="False">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource MutedText}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <EventSetter Event="MouseDoubleClick"
                                     Handler="TreeViewItem_MouseDoubleClick"/>
                        <EventSetter Event="PreviewMouseRightButtonDown"
                                     Handler="TreeViewItem_RightClick"/>
                        <EventSetter Event="Loaded"
                                     Handler="TreeViewItem_Loaded"/>
                        <EventSetter Event="PreviewMouseLeftButtonDown"
                                     Handler="TreeViewItem_PreviewMouseLeftButtonDown"/>
                        <EventSetter Event="PreviewMouseMove"
                                     Handler="TreeViewItem_PreviewMouseMove"/>
                        <EventSetter Event="DragOver"
                                     Handler="TreeViewItem_DragOver"/>
                        <EventSetter Event="Drop"
                                     Handler="TreeViewItem_Drop"/>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Grid>
    </Grid>
</UserControl>