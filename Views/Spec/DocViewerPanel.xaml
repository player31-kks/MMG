<UserControl x:Class="MMG.Views.Spec.DocViewerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MMG.Converters"
             xmlns:viewModels="clr-namespace:MMG.ViewModels.Spec"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1200">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <Style x:Key="SectionCardStyle"
                   TargetType="Border">
                <Setter Property="Background"
                        Value="White"/>
                <Setter Property="BorderBrush"
                        Value="#E5E7EB"/>
                <Setter Property="BorderThickness"
                        Value="1"/>
                <Setter Property="CornerRadius"
                        Value="16"/>
                <Setter Property="Padding"
                        Value="20"/>
            </Style>

            <Style x:Key="SectionTitleStyle"
                   TargetType="TextBlock">
                <Setter Property="FontSize"
                        Value="18"/>
                <Setter Property="FontWeight"
                        Value="SemiBold"/>
                <Setter Property="Foreground"
                        Value="#111827"/>
            </Style>

            <Style x:Key="PillBadgeStyle"
                   TargetType="Border">
                <Setter Property="CornerRadius"
                        Value="999"/>
                <Setter Property="Padding"
                        Value="10,4"/>
                <Setter Property="Background"
                        Value="#E0F2FE"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#F4F7FB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#FBFCFE"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="20,18"
                        Background="#FFFFFF"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Spec Navigator"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <TextBlock Text="{Binding CurrentSpec.Info.Title, Mode=OneWay}"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1"
                            Margin="20,16,20,16">
                    <TextBlock Text="Search"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#6B7280"/>
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,8,0,8"
                             Padding="12,8"
                             BorderBrush="#D1D5DB"
                             BorderThickness="1"
                             Background="White"
                             FontSize="13"/>
                    <TextBlock Text="{Binding SearchResultSummary, Mode=OneWay}"
                               FontSize="12"
                               Foreground="#6B7280"/>

                    <Button Command="{Binding SelectOverviewCommand}"
                            Margin="0,16,0,0"
                            Padding="14,12"
                            BorderThickness="0"
                            HorizontalContentAlignment="Stretch"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"
                                        Value="#F3F4F6"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOverviewSelected}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#E0F2FE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel>
                            <TextBlock Text="Overview"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBlock Text="스펙 전체 정보와 서버 목록"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#6B7280"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,0,14,20">
                        <TextBlock Text="Messages"
                                   Margin="6,0,0,8"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7280"/>

                        <ItemsControl ItemsSource="{Binding MessageGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:DocMessageGroup}">
                                    <Expander IsExpanded="{Binding IsExpanded}"
                                              Margin="0,0,0,10"
                                              Background="White"
                                              BorderBrush="#E5E7EB"
                                              BorderThickness="1">
                                        <Expander.Header>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#111827"/>
                                                <Border Grid.Column="1"
                                                        Background="#EEF2FF"
                                                        CornerRadius="999"
                                                        Padding="8,2">
                                                    <TextBlock Text="{Binding MessageCount}"
                                                               FontSize="11"
                                                               Foreground="#4338CA"/>
                                                </Border>
                                            </Grid>
                                        </Expander.Header>
                                        <ItemsControl ItemsSource="{Binding Messages}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:DocMessageItem}">
                                                    <Button Command="{Binding DataContext.SelectMessageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="8,6,8,2"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Cursor="Hand">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="Root"
                                                                                    Background="#FFFFFF"
                                                                                    BorderBrush="#E5E7EB"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="14"
                                                                                    Padding="12">
                                                                                <ContentPresenter/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver"
                                                                                         Value="True">
                                                                                    <Setter TargetName="Root"
                                                                                            Property="Background"
                                                                                            Value="#F8FAFC"/>
                                                                                </Trigger>
                                                                                <DataTrigger Binding="{Binding IsSelected}"
                                                                                             Value="True">
                                                                                    <Setter TargetName="Root"
                                                                                            Property="Background"
                                                                                            Value="#E0F2FE"/>
                                                                                    <Setter TargetName="Root"
                                                                                            Property="BorderBrush"
                                                                                            Value="#38BDF8"/>
                                                                                </DataTrigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#111827"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <Border Grid.Column="1"
                                                                    Style="{StaticResource PillBadgeStyle}"
                                                                    Background="#DBEAFE"
                                                                    Margin="8,0,0,0">
                                                                <TextBlock Text="{Binding MessageIdLiteral}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="11"
                                                                           Foreground="#1D4ED8"/>
                                                            </Border>

                                                            <TextBlock Grid.Row="1"
                                                                       Grid.ColumnSpan="2"
                                                                       Margin="0,6,0,0"
                                                                       FontSize="11"
                                                                       Foreground="#6B7280"
                                                                       Text="{Binding Description}"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <StackPanel Grid.Row="2"
                                                                        Grid.ColumnSpan="2"
                                                                        Orientation="Horizontal"
                                                                        Margin="0,10,0,0">
                                                                <TextBlock Text="{Binding TotalSizeText}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="11"
                                                                           Foreground="#0369A1"/>
                                                                <TextBlock Text=" · "
                                                                           FontSize="11"
                                                                           Foreground="#9CA3AF"/>
                                                                <TextBlock FontSize="11"
                                                                           Foreground="#6B7280">
                                                                    <Run Text="H "/>
                                                                    <Run Text="{Binding HeaderCount}"/>
                                                                    <Run Text=" / P "/>
                                                                    <Run Text="{Binding PayloadCount}"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="24">
                <Grid Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Style="{StaticResource SectionCardStyle}"
                            Background="#FEF2F2"
                            BorderBrush="#FCA5A5"
                            MaxWidth="860"
                            HorizontalAlignment="Center"
                            Padding="28">
                        <StackPanel>
                            <TextBlock Text="파싱 오류"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#B91C1C"/>
                            <TextBlock Text="현재 IDL 문서를 문서 화면으로 변환하지 못했습니다."
                                       Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="#7F1D1D"/>
                            <Border Margin="0,18,0,0"
                                    Background="White"
                                    BorderBrush="#FECACA"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16">
                                <TextBlock Text="{Binding ErrorMessage}"
                                           TextWrapping="Wrap"
                                           FontFamily="Consolas"
                                           Foreground="#7F1D1D"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Visibility="{Binding IsOverviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentSpec.Info.Title, Mode=OneWay}"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#111827"/>
                            <TextBlock Text="IDL 기반 API spec overview"
                                       Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="#6B7280"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding OverviewCards}"
                                  Margin="0,20,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:DocSummaryCard}">
                                <Border Style="{StaticResource SectionCardStyle}"
                                        Width="220"
                                        Margin="0,0,16,16">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title, Mode=OneWay}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Value, Mode=OneWay}"
                                                   Margin="0,8,0,0"
                                                   FontSize="26"
                                                   FontWeight="Bold"
                                                   Foreground="#111827"/>
                                        <TextBlock Text="{Binding Description, Mode=OneWay}"
                                                   Margin="0,8,0,0"
                                                   FontSize="12"
                                                   Foreground="#6B7280"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="Servers"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <ItemsControl ItemsSource="{Binding Servers}"
                                          Margin="0,16,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E5E7EB"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="220"/>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#111827"/>
                                                <Border Grid.Column="1"
                                                        Background="#DCFCE7"
                                                        CornerRadius="999"
                                                        Padding="10,4"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock FontFamily="Consolas"
                                                               Foreground="#166534">
                                                        <Run Text="{Binding IpAddress}"/>
                                                        <Run Text=":"/>
                                                        <Run Text="{Binding Port}"/>
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock Grid.Column="2"
                                                           Margin="12,0,0,0"
                                                           Text="{Binding Description}"
                                                           Foreground="#6B7280"
                                                           TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Visibility="{Binding HasSelectedMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SelectedMessageTitle, Mode=OneWay}"
                                                   FontSize="30"
                                                   FontWeight="Bold"
                                                   Foreground="#111827"/>
                                        <Border Style="{StaticResource PillBadgeStyle}"
                                                Margin="12,4,0,0"
                                                Background="#DBEAFE"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding SelectedMessageIdBadge, Mode=OneWay}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#1D4ED8"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding SelectedMessageDescription, Mode=OneWay}"
                                               Margin="0,10,0,0"
                                               FontSize="14"
                                               Foreground="#6B7280"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding CreateApiRequestCommand}"
                                        Padding="18,10"
                                        BorderThickness="0"
                                        Background="#0F6CBD"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        VerticalAlignment="Top">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="10"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    API 생성
                                </Button>
                            </Grid>

                            <UniformGrid Columns="4"
                                         Margin="0,20,0,0">
                            <Border Margin="0,0,14,0"
                                    Background="#F8FAFC"
                                    CornerRadius="12"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Struct"
                                               FontSize="11"
                                               Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding SelectedMessageStructName, Mode=OneWay}"
                                               Margin="0,6,0,0"
                                               FontFamily="Consolas"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,14,0"
                                    Background="#F8FAFC"
                                    CornerRadius="12"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Total Size"
                                               FontSize="11"
                                               Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding SelectedMessageTotalSize, Mode=OneWay}"
                                               Margin="0,6,0,0"
                                               FontFamily="Consolas"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,14,0"
                                    Background="#F8FAFC"
                                    CornerRadius="12"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Endpoint"
                                               FontSize="11"
                                               Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding SelectedMessageEndpoint, Mode=OneWay}"
                                               Margin="0,6,0,0"
                                               FontFamily="Consolas"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                                <Border Background="#F8FAFC"
                                        CornerRadius="12"
                                        Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Endian / Timeout"
                                                   FontSize="11"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Margin="0,6,0,0"
                                                   FontFamily="Consolas"
                                                   FontSize="14"
                                                   FontWeight="SemiBold">
                                            <Run Text="{Binding SelectedMessageEndian, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding SelectedMessageTimeout, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0,20,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Header"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <Border Grid.Column="1"
                                        Style="{StaticResource PillBadgeStyle}"
                                        Background="#E0F2FE"
                                        Margin="10,0,0,0">
                                    <TextBlock Text="{Binding SelectedMessageHeaderCount, Mode=OneWay}"
                                               Foreground="#075985"/>
                                </Border>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding SelectedMessage.HeaderFields}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:DocFieldItem}">
                                        <Border BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14"
                                                Margin="0,0,0,10"
                                                Background="#F8FAFC">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontFamily="Consolas"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#111827"/>
                                                        <Border Visibility="{Binding IsMessageIdField, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                Background="#DBEAFE"
                                                                CornerRadius="999"
                                                                Padding="8,2"
                                                                Margin="8,0,0,0">
                                                            <TextBlock Text="MsgID"
                                                                       FontSize="10"
                                                                       Foreground="#1D4ED8"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding TypeDisplay}"
                                                               FontFamily="Consolas"
                                                               Foreground="#6D28D9"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ByteSizeText}"
                                                               FontFamily="Consolas"
                                                               Foreground="#0369A1"/>
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding Endian}"
                                                               Foreground="#334155"/>
                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding Description}"
                                                               Foreground="#6B7280"
                                                               TextWrapping="Wrap"/>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding BitFields}"
                                                              Visibility="{Binding HasBitFields, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                              Margin="0,12,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type viewModels:DocBitFieldItem}">
                                                            <Border Background="#FEF3C7"
                                                                    BorderBrush="#FDE68A"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    Padding="10"
                                                                    Margin="0,0,0,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="140"/>
                                                                        <ColumnDefinition Width="100"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="100"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontFamily="Consolas"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#92400E"/>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding BitRange}"
                                                                               FontFamily="Consolas"
                                                                               Foreground="#B45309"/>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding Description}"
                                                                               Foreground="#6B7280"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Column="3"
                                                                               Text="{Binding MaxValueText}"
                                                                               HorizontalAlignment="Right"
                                                                               FontFamily="Consolas"
                                                                               Foreground="#92400E"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0,20,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Payload"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <Border Grid.Column="1"
                                        Style="{StaticResource PillBadgeStyle}"
                                        Background="#ECFCCB">
                                    <TextBlock Text="{Binding SelectedMessagePayloadCount, Mode=OneWay}"
                                               Foreground="#3F6212"/>
                                </Border>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding SelectedMessage.PayloadFields}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:DocFieldItem}">
                                        <Border BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14"
                                                Margin="0,0,0,10"
                                                Background="White">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontFamily="Consolas"
                                                               FontWeight="SemiBold"
                                                               Foreground="#111827"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding TypeDisplay}"
                                                               FontFamily="Consolas"
                                                               Foreground="#6D28D9"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ByteSizeText}"
                                                               FontFamily="Consolas"
                                                               Foreground="#0369A1"/>
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding Endian}"
                                                               Foreground="#334155"/>
                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding Description}"
                                                               Foreground="#6B7280"
                                                               TextWrapping="Wrap"/>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding BitFields}"
                                                              Visibility="{Binding HasBitFields, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                              Margin="0,12,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type viewModels:DocBitFieldItem}">
                                                            <Border Background="#FEF3C7"
                                                                    BorderBrush="#FDE68A"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    Padding="10"
                                                                    Margin="0,0,0,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="140"/>
                                                                        <ColumnDefinition Width="100"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="100"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontFamily="Consolas"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#92400E"/>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding BitRange}"
                                                                               FontFamily="Consolas"
                                                                               Foreground="#B45309"/>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding Description}"
                                                                               Foreground="#6B7280"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Column="3"
                                                                               Text="{Binding MaxValueText}"
                                                                               HorizontalAlignment="Right"
                                                                               FontFamily="Consolas"
                                                                               Foreground="#92400E"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
