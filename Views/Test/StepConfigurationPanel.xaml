<UserControl x:Class="MMG.Views.Test.StepConfigurationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:MMG.Models"
             xmlns:converters="clr-namespace:MMG.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="350"
             Background="{StaticResource PanelBackground}">

    <UserControl.Resources>
        <converters:StringToBooleanConverter x:Key="EqualToStringConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource SoftAccent}"
                BorderBrush="{StaticResource MutedBorder}"
                BorderThickness="0"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="스텝 설정"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryColor}"/>
                    <TextBlock Text="선택된 테스트 스텝 구성"
                               FontSize="12"
                               Foreground="{StaticResource MutedText}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="💾"
                        Command="{Binding SaveStepCommand}"
                        Width="32"
                        Height="32"
                        FontSize="16"
                        Style="{StaticResource ModernButton}"
                        ToolTip="스텝 저장"/>
            </Grid>
        </Border>

        <!-- Configuration Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="8,0,8,8">
            <StackPanel>
                <!-- Step Basic Info -->
                <Border Style="{StaticResource TestCard}"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <!-- 섹션 헤더 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="3" Height="14" CornerRadius="2"
                                    Background="{StaticResource PrimaryColor}"
                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="기본 정보"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryColor}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="이름"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding SelectedStep.Name, Mode=TwoWay}"
                                     Style="{StaticResource ModernTextBox}"
                                     FontSize="12"
                                     Padding="8,4"
                                     Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="타입"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      SelectedValue="{Binding SelectedStep.StepType, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      IsEditable="False"
                                      Style="{StaticResource CompactComboBox}"
                                      Margin="0,0,0,8">
                                <ComboBoxItem Tag="Immediate">즉시 실행</ComboBoxItem>
                                <ComboBoxItem Tag="PreDelayed">사전 지연</ComboBoxItem>
                                <ComboBoxItem Tag="PostDelayed">사후 지연</ComboBoxItem>
                                <ComboBoxItem Tag="Periodic">주기적 실행</ComboBoxItem>
                                <ComboBoxItem Tag="AbsoluteDelayed">절대 지연 (시나리오 시작 기준)</ComboBoxItem>
                                <ComboBoxItem Tag="WaitForMessage">메시지 수신 대기</ComboBoxItem>
                                <ComboBoxItem Tag="ReceiveAndReply">수신 후 응답</ComboBoxItem>
                            </ComboBox>

                            <!-- 체크박스 행 -->
                            <StackPanel Grid.Row="2" Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Orientation="Horizontal"
                                        Margin="0,4,0,0">
                                <CheckBox Content="활성화"
                                          IsChecked="{Binding SelectedStep.IsEnabled, Mode=TwoWay}"
                                          Style="{StaticResource ModernCheckBox}"
                                          Margin="0,0,16,0"/>
                                <CheckBox Content="백그라운드 실행"
                                          IsChecked="{Binding SelectedStep.IsBackground, Mode=TwoWay}"
                                          Style="{StaticResource ModernCheckBox}"
                                          ToolTip="체크하면 이 스텝이 백그라운드에서 실행되고 다음 스텝으로 바로 진행됩니다"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Request Configuration -->
                <Border Style="{StaticResource TestCard}"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="3" Height="14" CornerRadius="2"
                                    Background="{StaticResource SecondaryColor}"
                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="요청 설정"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryColor}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 공통 - 저장된 요청 선택 -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="요청"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedText}"
                                       VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding SavedRequests}"
                                      SelectedValue="{Binding SelectedStep.SavedRequestId, Mode=TwoWay}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource CompactComboBox}"/>
                        </Grid>
                        <TextBlock Text="미선택 시 지연만 수행 (요청 전송 없음)"
                                   FontSize="10"
                                   Foreground="{StaticResource MutedText}"
                                   FontStyle="Italic"
                                   Margin="72,0,0,10"/>

                        <!-- Immediate 설정 (추가 설정 없음) -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStep.StepType}"
                                                Value="Immediate">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="💡 요청이 지연 없이 즉시 실행됩니다."
                                       FontSize="11"
                                       Foreground="{StaticResource MutedText}"
                                       FontStyle="Italic"/>
                        </StackPanel>

                        <!-- PreDelayed 설정 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStep.StepType}"
                                                Value="PreDelayed">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="사전 지연:"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SelectedStep.PreDelayMs, Mode=TwoWay}"
                                         Style="{StaticResource ModernTextBox}"
                                         FontSize="12"
                                         Padding="8,4"/>
                                <TextBlock Grid.Column="2"
                                           Text="ms"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>
                            </Grid>
                            <TextBlock Text="💡 지정된 시간(ms) 대기 후 요청이 실행됩니다."
                                       FontSize="11"
                                       Foreground="{StaticResource MutedText}"
                                       FontStyle="Italic"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- PostDelayed 설정 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStep.StepType}"
                                                Value="PostDelayed">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="사후 지연:"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SelectedStep.PostDelayMs, Mode=TwoWay}"
                                         Style="{StaticResource ModernTextBox}"
                                         FontSize="12"
                                         Padding="8,4"/>
                                <TextBlock Grid.Column="2"
                                           Text="ms"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>
                            </Grid>
                            <TextBlock Text="💡 요청 실행 후 지정된 시간(ms) 동안 대기합니다."
                                       FontSize="11"
                                       Foreground="{StaticResource MutedText}"
                                       FontStyle="Italic"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Periodic 설정 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStep.StepType}"
                                                Value="Periodic">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="실행 간격:"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SelectedStep.IntervalMs, Mode=TwoWay}"
                                         Style="{StaticResource ModernTextBox}"
                                         FontSize="12"
                                         Padding="8,4"/>
                                <TextBlock Grid.Column="2"
                                           Text="ms"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>
                            </Grid>
                            <!-- 반복 횟수 (무한 반복이 꺼져 있을 때만 표시) -->
                            <Grid Margin="0,0,0,8"
                                  Visibility="{Binding SelectedStep.RepeatCountVisibility}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="반복 횟수:"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SelectedStep.RepeatCount, Mode=TwoWay}"
                                         Style="{StaticResource ModernTextBox}"
                                         FontSize="12"
                                         Padding="8,4"/>
                                <TextBlock Grid.Column="2"
                                           Text="회"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>
                            </Grid>

                            <!-- 무한 반복 토글 블록 -->
                            <Border Background="#F8F7FF"
                                    BorderBrush="#C5BDFA"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Border Width="3"
                                                Height="13"
                                                CornerRadius="2"
                                                Background="{StaticResource PrimaryColor}"
                                                Margin="0,0,7,0"
                                                VerticalAlignment="Center"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryColor}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="무한 반복"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedStep.IsInfiniteRepeat}" Value="True">
                                                                <Setter Property="Text" Value="무한 반복 (∞)"/>
                                                                <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="중지 버튼을 누를 때까지 계속 전송"
                                                       FontSize="10"
                                                       Foreground="{StaticResource MutedText}"
                                                       Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- 토글 스위치 -->
                                    <ToggleButton Grid.Column="1"
                                                  IsChecked="{Binding SelectedStep.IsInfiniteRepeat, Mode=TwoWay}"
                                                  Width="40"
                                                  Height="20"
                                                  Cursor="Hand">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="#DEE2E6"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="Track"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="10"
                                                                    Width="40"
                                                                    Height="20">
                                                                <Border x:Name="Thumb"
                                                                        Width="14"
                                                                        Height="14"
                                                                        CornerRadius="7"
                                                                        Background="White"
                                                                        HorizontalAlignment="Left"
                                                                        Margin="3,0,0,0"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Track" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                                                    <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                                                    <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource MutedText}"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="💡 지정된 간격(ms)으로 반복 횟수만큼 요청을 실행합니다."/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedStep.IsInfiniteRepeat}" Value="True">
                                                <Setter Property="Text" Value="💡 무한 반복 모드: 지정된 간격으로 계속 전송합니다. 헤더 ■ 중지 버튼으로 종료하세요."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- AbsoluteDelayed 설정 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStep.StepType}"
                                                Value="AbsoluteDelayed">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="시나리오 시작 후:"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SelectedStep.StartDelayFromScenarioMs, Mode=TwoWay}"
                                         Style="{StaticResource ModernTextBox}"
                                         FontSize="12"
                                         Padding="8,4"/>
                                <TextBlock Grid.Column="2"
                                           Text="ms"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>
                            </Grid>
                            <TextBlock Text="💡 시나리오 시작 시점을 기준으로 지정된 시간(ms) 후에 실행됩니다."
                                       FontSize="11"
                                       Foreground="{StaticResource MutedText}"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- WaitForMessage 설정 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStep.StepType}"
                                                Value="WaitForMessage">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <!-- 타임아웃 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="타임아웃:" FontSize="12"
                                           Foreground="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SelectedStep.ReceiveTimeoutMs, Mode=TwoWay}"
                                         Style="{StaticResource ModernTextBox}" FontSize="12" Padding="8,4"/>
                                <TextBlock Grid.Column="2" Text="ms" FontSize="12"
                                           Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>

                            <!-- 길이 필터 (항상 적용) -->
                            <Border Background="#F8F7FF" BorderBrush="#C5BDFA" BorderThickness="1"
                                    CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="3" Height="13" CornerRadius="2"
                                                Background="{StaticResource PrimaryColor}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="길이 필터" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryColor}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="길이" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding SelectedStep.LengthFilterValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}" FontSize="12" Padding="8,4"/>
                                        <Border Grid.Column="2" Background="#EEF2FF" CornerRadius="4"
                                                Padding="6,3" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="byte" FontSize="10"
                                                       Foreground="{StaticResource PrimaryColor}" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ID 필터 (항상 적용) -->
                            <Border Background="#F8F7FF" BorderBrush="#C5BDFA" BorderThickness="1"
                                    CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="3" Height="13" CornerRadius="2"
                                                Background="{StaticResource PrimaryColor}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="ID 필터" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryColor}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Offset" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding SelectedStep.IdFilterOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}" FontSize="12" Padding="8,4"/>
                                        <Border Grid.Column="2" Background="#EEF2FF" CornerRadius="4"
                                                Padding="6,3" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="byte" FontSize="10"
                                                       Foreground="{StaticResource PrimaryColor}" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="타입" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <RadioButton Grid.Column="0" Content="Byte" GroupName="IdFilterTypeWFM"
                                                         IsChecked="{Binding SelectedStep.IdFilterType, Converter={StaticResource EqualToStringConverter}, ConverterParameter=Byte, Mode=TwoWay}"
                                                         Margin="0,0,3,0">
                                                <RadioButton.Style>
                                                    <Style TargetType="RadioButton">
                                                        <Setter Property="Background" Value="#F0F0F0"/>
                                                        <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="RadioButton">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                            BorderBrush="{StaticResource MutedBorder}" BorderThickness="1"
                                                                            CornerRadius="5" Padding="0,5">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </RadioButton.Style>
                                            </RadioButton>
                                            <RadioButton Grid.Column="1" Content="UInt16" GroupName="IdFilterTypeWFM"
                                                         IsChecked="{Binding SelectedStep.IdFilterType, Converter={StaticResource EqualToStringConverter}, ConverterParameter=UInt16, Mode=TwoWay}"
                                                         Margin="3,0,0,0">
                                                <RadioButton.Style>
                                                    <Style TargetType="RadioButton">
                                                        <Setter Property="Background" Value="#F0F0F0"/>
                                                        <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="RadioButton">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                            BorderBrush="{StaticResource MutedBorder}" BorderThickness="1"
                                                                            CornerRadius="5" Padding="0,5">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </RadioButton.Style>
                                            </RadioButton>
                                        </Grid>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="ID 값" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding SelectedStep.IdFilterValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}" FontSize="12" Padding="8,4"/>
                                        <Border Grid.Column="2" Background="#EEF2FF" CornerRadius="4"
                                                Padding="6,3" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="dec" FontSize="10"
                                                       Foreground="{StaticResource PrimaryColor}" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 추가 필터 (동적) -->
                            <Border Background="#F0FFF4" BorderBrush="#86EFAC" BorderThickness="1"
                                    CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="3" Height="13" CornerRadius="2"
                                                    Background="#22C55E" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="추가 필터" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryColor}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="추가"
                                                Command="{Binding SelectedStep.AddFieldFilterCommand}"
                                                Style="{StaticResource ModernButton}"
                                                FontSize="10" Height="24" Padding="8,2" Margin="0"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding SelectedStep.FieldFilters}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,4" Background="White"
                                                        BorderBrush="#D1FAE5" BorderThickness="1"
                                                        CornerRadius="5" Padding="8,5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="48"/>
                                                            <ColumnDefinition Width="6"/>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="24"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="offset"
                                                                   FontSize="10" Foreground="{StaticResource MutedText}"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding Offset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource ModernTextBox}" FontSize="11" Padding="4,2"/>
                                                        <ComboBox Grid.Column="3"
                                                                  SelectedValue="{Binding Type, Mode=TwoWay}"
                                                                  SelectedValuePath="Content"
                                                                  Style="{StaticResource CompactComboBox}"
                                                                  FontSize="11" Padding="4,2">
                                                            <ComboBoxItem Content="Byte"/>
                                                            <ComboBoxItem Content="Int16"/>
                                                            <ComboBoxItem Content="UInt16"/>
                                                            <ComboBoxItem Content="Int"/>
                                                            <ComboBoxItem Content="UInt"/>
                                                            <ComboBoxItem Content="Float"/>
                                                        </ComboBox>
                                                        <TextBlock Grid.Column="5" Text="="
                                                                   FontSize="13" FontWeight="Bold"
                                                                   Foreground="{StaticResource MutedText}"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBox Grid.Column="6"
                                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource ModernTextBox}" FontSize="11" Padding="4,2"/>
                                                        <Button Grid.Column="7"
                                                                Content="✕" Width="22" Height="22" FontSize="9"
                                                                Padding="0" Margin="4,0,0,0"
                                                                Command="{Binding DataContext.SelectedStep.RemoveFieldFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                    <Setter Property="Cursor" Value="Hand"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="#FECACA"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="추가 필터 없음 (+ 추가 버튼으로 필드 조건 추가)"
                                               FontSize="11" Foreground="{StaticResource MutedText}"
                                               FontStyle="Italic" HorizontalAlignment="Center" Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStep.FieldFilters.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="💡 길이·ID 필터는 항상 적용됩니다 (길이 0이면 길이 체크 생략). 추가 필터로 특정 오프셋의 필드 값을 추가 검사할 수 있습니다."
                                       FontSize="11" Foreground="{StaticResource MutedText}"
                                       FontStyle="Italic" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- ReceiveAndReply 설정 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStep.StepType}"
                                                Value="ReceiveAndReply">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="타임아웃:"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SelectedStep.ReceiveTimeoutMs, Mode=TwoWay}"
                                         Style="{StaticResource ModernTextBox}"
                                         FontSize="12"
                                         Padding="8,4"/>
                                <TextBlock Grid.Column="2"
                                           Text="ms"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="응답 요청:"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding SavedRequests}"
                                          SelectedValue="{Binding SelectedStep.ResponseRequestId, Mode=TwoWay}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource CompactComboBox}"/>
                            </Grid>
                            <!-- 길이 필터 블록 (ReceiveAndReply) -->
                            <Border Background="#F8F7FF"
                                    BorderBrush="#C5BDFA"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,10,0,0">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="3"
                                                    Height="13"
                                                    CornerRadius="2"
                                                    Background="{StaticResource PrimaryColor}"
                                                    Margin="0,0,7,0"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="길이 필터"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryColor}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="길이"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedText}"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding SelectedStep.LengthFilterValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}"
                                                 FontSize="12"
                                                 Padding="8,4"/>
                                        <Border Grid.Column="2"
                                                Background="#EEF2FF"
                                                CornerRadius="4"
                                                Padding="6,3"
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="byte"
                                                       FontSize="10"
                                                       Foreground="{StaticResource PrimaryColor}"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <!-- ID 필터 블록 (ReceiveAndReply) -->
                            <Border Background="#F8F7FF"
                                    BorderBrush="#C5BDFA"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,10,0,0">
                                <StackPanel>
                                    <!-- 헤더 행 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="3"
                                                    Height="13"
                                                    CornerRadius="2"
                                                    Background="{StaticResource PrimaryColor}"
                                                    Margin="0,0,7,0"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="ID 필터"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryColor}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      IsChecked="{Binding SelectedStep.UseIdFilter, Mode=TwoWay}"
                                                      Width="40"
                                                      Height="20"
                                                      Cursor="Hand">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton">
                                                    <Setter Property="Background" Value="#DEE2E6"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Border x:Name="Track"
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="10"
                                                                        Width="40"
                                                                        Height="20">
                                                                    <Border x:Name="Thumb"
                                                                            Width="14"
                                                                            Height="14"
                                                                            CornerRadius="7"
                                                                            Background="White"
                                                                            HorizontalAlignment="Left"
                                                                            Margin="3,0,0,0"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Setter TargetName="Track" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                                                        <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                                                        <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>
                                    </Grid>

                                    <!-- 필터 설정 -->
                                    <StackPanel Visibility="{Binding SelectedStep.IdFilterVisibility}"
                                                Margin="0,10,0,0">
                                        <!-- Offset 행 -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="Offset"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource MutedText}"
                                                       VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding SelectedStep.IdFilterOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBox}"
                                                     FontSize="12"
                                                     Padding="8,4"/>
                                            <Border Grid.Column="2"
                                                    Background="#EEF2FF"
                                                    CornerRadius="4"
                                                    Padding="6,3"
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="byte"
                                                           FontSize="10"
                                                           Foreground="{StaticResource PrimaryColor}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>

                                        <!-- 타입 행 -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="타입"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource MutedText}"
                                                       VerticalAlignment="Center"/>
                                            <Grid Grid.Column="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <RadioButton Grid.Column="0"
                                                             Content="Byte"
                                                             GroupName="IdFilterTypeRAR"
                                                             IsChecked="{Binding SelectedStep.IdFilterType, Converter={StaticResource EqualToStringConverter}, ConverterParameter=Byte, Mode=TwoWay}"
                                                             Margin="0,0,3,0">
                                                    <RadioButton.Style>
                                                        <Style TargetType="RadioButton">
                                                            <Setter Property="Background" Value="#F0F0F0"/>
                                                            <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="RadioButton">
                                                                        <Border x:Name="Bd"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{StaticResource MutedBorder}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="5"
                                                                                Padding="0,5">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                                                                <Setter Property="Foreground" Value="White"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </RadioButton.Style>
                                                </RadioButton>
                                                <RadioButton Grid.Column="1"
                                                             Content="UInt16"
                                                             GroupName="IdFilterTypeRAR"
                                                             IsChecked="{Binding SelectedStep.IdFilterType, Converter={StaticResource EqualToStringConverter}, ConverterParameter=UInt16, Mode=TwoWay}"
                                                             Margin="3,0,0,0">
                                                    <RadioButton.Style>
                                                        <Style TargetType="RadioButton">
                                                            <Setter Property="Background" Value="#F0F0F0"/>
                                                            <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="RadioButton">
                                                                        <Border x:Name="Bd"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{StaticResource MutedBorder}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="5"
                                                                                Padding="0,5">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                                                                <Setter Property="Foreground" Value="White"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </RadioButton.Style>
                                                </RadioButton>
                                            </Grid>
                                        </Grid>

                                        <!-- ID 값 행 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="ID 값"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource MutedText}"
                                                       VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding SelectedStep.IdFilterValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBox}"
                                                     FontSize="12"
                                                     Padding="8,4"/>
                                            <Border Grid.Column="2"
                                                    Background="#EEF2FF"
                                                    CornerRadius="4"
                                                    Padding="6,3"
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="dec"
                                                           FontSize="10"
                                                           Foreground="{StaticResource PrimaryColor}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="💡 시나리오 포트에서 메시지 수신 후 지정된 응답 요청을 송신자에게 전송합니다. ID 필터가 켜진 경우 지정한 ID 값이 일치하는 메시지만 처리됩니다."
                                       FontSize="11"
                                       Foreground="{StaticResource MutedText}"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>


            </StackPanel>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility"
                            Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedStep}"
                                     Value="{x:Null}">
                            <Setter Property="Visibility"
                                    Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="⚙️"
                       FontSize="48"
                       HorizontalAlignment="Center"
                       Opacity="0.3"
                       Margin="0,0,0,16"/>
            <TextBlock Text="스텝을 선택하세요"
                       FontSize="16"
                       Foreground="{StaticResource MutedText}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="테스트 스텝을 클릭하여 설정을 편집하세요"
                       FontSize="12"
                       Foreground="#ADB5BD"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2"
                Style="{StaticResource PanelFooter}">
            <Grid HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <Button Content="테스트"
                            Command="{Binding RunTestStepCommand}"
                            CommandParameter="{Binding SelectedStep}"
                            Style="{StaticResource ModernButton}"
                            Width="50"
                            Height="30"
                            FontSize="{DynamicResource text-sm}"/>
                    <Button Content="삭제"
                            Command="{Binding DeleteTestStepCommand}"
                            CommandParameter="{Binding SelectedStep}"
                            Style="{StaticResource CancelButtonStyle}"
                            Background="{StaticResource WarningColor}"
                            Width="50"
                            Height="30"
                            FontSize="{DynamicResource text-sm}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>